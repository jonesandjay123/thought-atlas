{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thought-atlas.local/schemas/graph_patch.schema.json",
  "title": "Thought Atlas Graph Patch",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch_id", "digest_id", "created_at", "operations"],
  "properties": {
    "patch_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "digest_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "created_at": { "type": "string", "format": "date-time" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "rationale"],
        "properties": {
          "op": { "type": "string", "enum": ["add_node", "update_node", "add_edge", "update_edge"] },
          "rationale": { "type": "string", "minLength": 1 },
          "node": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "title", "body", "source_refs", "confidence", "tags"],
            "properties": {
              "id": { "type": "string" },
              "kind": { "type": "string" },
              "title": { "type": "string" },
              "body": { "type": "string" },
              "source_refs": { "type": "array" },
              "confidence": { "type": "number" },
              "tags": { "type": "array" }
            }
          },
          "node_id": { "type": "string" },
          "edge_id": { "type": "string" },
          "fields": { "type": "object" },
          "edge": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "from", "to", "relation", "confidence", "source_refs", "rationale"],
            "properties": {
              "id": { "type": "string" },
              "from": { "type": "string" },
              "to": { "type": "string" },
              "relation": {
                "type": "string",
                "enum": ["supports", "contrasts", "extends", "depends_on", "blocks", "duplicates", "resonates_with"]
              },
              "weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "source_refs": { "type": "array", "minItems": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
