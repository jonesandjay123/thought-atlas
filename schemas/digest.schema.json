{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thought-atlas.local/schemas/digest.schema.json",
  "title": "Thought Atlas Digest",
  "type": "object",
  "additionalProperties": false,
  "required": ["digest_id", "source_id", "created_at", "summary", "items"],
  "properties": {
    "digest_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "source_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "created_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "title", "body", "source_refs", "confidence", "tags"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "kind": {
            "type": "string",
            "enum": ["claim", "question", "decision", "pattern", "action", "reference"]
          },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_id", "path"],
              "properties": {
                "source_id": { "type": "string" },
                "path": { "type": "string" },
                "start_line": { "type": "integer", "minimum": 1 },
                "end_line": { "type": "integer", "minimum": 1 },
                "quote": { "type": "string" }
              }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
